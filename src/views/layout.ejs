<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>航空部件生命周期与维修管理系统</title>
  <link rel="stylesheet" href="/style.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
</head>
<body>
  <nav>
    <div class="nav-brand">Aircraft MS</div>
    <div class="nav-links">
      <a href="/">仪表盘</a>
      <a href="/aircraft">飞机</a>
      <a href="/components">部件</a>
      <a href="/installations">安装</a>
      <a href="/flightlogs">飞行</a>
      <a href="/maintenance">维修</a>
      <a href="/retirements">退役</a>
      <a href="/query">查询</a>
    </div>
  </nav>

  <main>
    <% if (typeof error === 'string' && error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>
    <% if (typeof success === 'string' && success) { %>
      <div class="alert alert-success"><%= success %></div>
    <% } %>
    <%- body %>
  </main>
</body>
</html>
