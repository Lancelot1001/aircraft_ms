<h1>飞行-部件关联查询</h1>

<form method="GET" action="/flightlogs/parts">
  <div class="form-group">
    <label>飞机 <span class="required">*</span></label>
    <select name="aircraft_id" required>
      <option value="">-- 请选择 --</option>
      <% aircraftList.forEach(function(a) { %>
        <option value="<%= a.id %>" <%= selectedAircraft == a.id ? 'selected' : '' %>><%= a.aircraft_sn %> — <%= a.model %></option>
      <% }); %>
    </select>
  </div>

  <div class="form-group">
    <label>查询起始时间</label>
    <input type="datetime-local" name="start_time" value="<%= start_time %>">
  </div>

  <div class="form-group">
    <label>查询结束时间</label>
    <input type="datetime-local" name="end_time" value="<%= end_time %>">
    <p class="hint">留空则查询当前在位部件。填写时间段则查询该时段内该飞机上安装的所有部件。</p>
  </div>

  <button type="submit" class="btn btn-primary">查询</button>
</form>

<% if (parts.length > 0) { %>
  <h2>查询结果（<%= parts.length %> 个部件）</h2>
  <table>
    <thead>
      <tr>
        <th>部件编号</th>
        <th>型号</th>
        <th>类别</th>
        <th>安装位置</th>
        <th>安装时间</th>
        <th>拆卸时间</th>
      </tr>
    </thead>
    <tbody>
      <% parts.forEach(function(p) { %>
        <tr>
          <td><%= p.component_sn %></td>
          <td><%= p.model_name %></td>
          <td><%= p.category %></td>
          <td><%= p.position %></td>
          <td><%= p.installed_at %></td>
          <td><%= p.removed_at || '当前在位' %></td>
        </tr>
      <% }); %>
    </tbody>
  </table>
<% } else if (selectedAircraft) { %>
  <p>该时间段内没有匹配的部件记录。</p>
<% } %>
