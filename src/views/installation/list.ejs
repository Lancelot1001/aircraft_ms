<h1>安装记录</h1>

<p>
  <a href="/installations?active=1" class="btn">仅看当前在位</a>
  <a href="/installations" class="btn">全部记录</a>
</p>

<table>
  <thead>
    <tr>
      <th>ID</th>
      <th>部件编号</th>
      <th>型号</th>
      <th>飞机</th>
      <th>位置</th>
      <th>安装时间</th>
      <th>拆卸时间</th>
      <th>操作员</th>
    </tr>
  </thead>
  <tbody>
    <% if (installations.length) { %>
      <% installations.forEach(function(ir) { %>
        <tr>
          <td><%= ir.id %></td>
          <td><%= ir.component_sn %></td>
          <td><%= ir.model_name %></td>
          <td><%= ir.aircraft_sn_val %> (<%= ir.aircraft_model %>)</td>
          <td><%= ir.position %></td>
          <td><%= ir.installed_at %></td>
          <td><%= ir.removed_at || '<span class="status status-installed">在位</span>' %></td>
          <td><%= ir.operator_name || '—' %></td>
        </tr>
      <% }); %>
    <% } else { %>
      <tr><td colspan="8">暂无安装记录</td></tr>
    <% } %>
  </tbody>
</table>
