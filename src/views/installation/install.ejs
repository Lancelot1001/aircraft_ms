<h1>安装部件</h1>

<form method="POST" action="/installations/install">
  <div class="form-group">
    <label>选择部件 <span class="required">*</span></label>
    <select name="component_id" required>
      <option value="">-- 请选择可用部件 --</option>
      <% components.forEach(function(c) { %>
        <option value="<%= c.id %>" <%= form.component_id == c.id ? 'selected' : '' %>>
          <%= c.component_sn %> — <%= c.model_name %>
        </option>
      <% }); %>
    </select>
    <% if (!components.length) { %>
      <p class="hint">没有可用的部件，请先执行部件入库或确认部件状态为 available</p>
    <% } %>
  </div>

  <div class="form-group">
    <label>目标飞机 <span class="required">*</span></label>
    <select name="aircraft_id" required>
      <option value="">-- 请选择飞机 --</option>
      <% aircraft.forEach(function(a) { %>
        <option value="<%= a.id %>"><%= a.aircraft_sn %> — <%= a.model %></option>
      <% }); %>
    </select>
  </div>

  <div class="form-group">
    <label>安装位置 <span class="required">*</span></label>
    <input type="text" name="position" placeholder="如 左发挂架、电子设备舱" value="<%= form.position || '' %>" required>
  </div>

  <div class="form-group">
    <label>安装原因 <span class="required">*</span></label>
    <input type="text" name="install_reason" placeholder="如 新机初始安装、更换旧部件" value="<%= form.install_reason || '' %>" required>
  </div>

  <div class="form-group">
    <label>操作人员 <span class="required">*</span></label>
    <select name="operator_id" required>
      <option value="">-- 请选择操作人员 --</option>
      <% operators.forEach(function(o) { %>
        <option value="<%= o.id %>"><%= o.name %> (<%= o.role %>)</option>
      <% }); %>
    </select>
  </div>

  <button type="submit" class="btn btn-primary">确认安装</button>
</form>
