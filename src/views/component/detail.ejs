<h1>部件详情</h1>

<% if (!component) { %>
  <div class="alert alert-error">部件不存在</div>
  <a href="/components" class="btn">返回列表</a>
<% } else { %>

  <!-- 操作栏 — 根据部件状态显示不同操作 -->
  <% if (component.status === 'installed') { %>
    <div class="card" style="border-left:3px solid #2563EB; background:#F8FAFE;">
      <div style="display:flex; align-items:center; gap:12px;">
        <span style="font-weight:700;">可用操作：</span>
        <a href="/installations/swap" class="btn btn-warning">更换此部件</a>
        <a href="/installations/uninstall" class="btn">拆卸部件</a>
        <span style="color:#666;font-size:12px;margin-left:auto;">当前状态：<span class="badge badge-installed">installed</span></span>
      </div>
    </div>
  <% } else if (component.status === 'available') { %>
    <div class="card" style="border-left:3px solid #22C55E; background:#F8FDF8;">
      <div style="display:flex; align-items:center; gap:12px;">
        <span style="font-weight:700;">可用操作：</span>
        <a href="/installations/install" class="btn btn-success">安装此部件</a>
        <span style="color:#666;font-size:12px;margin-left:auto;">当前状态：<span class="badge badge-available">available</span></span>
      </div>
    </div>
  <% } else if (component.status === 'under_maintenance') { %>
    <div class="card" style="border-left:3px solid #F59E0B; background:#FFFDF5;">
      <span style="color:#92400E;font-size:13px;">该部件正在维修中，不可安装或拆卸。</span>
      <span style="color:#666;font-size:12px;margin-left:8px;">当前状态：<span class="badge badge-under_maintenance">under_maintenance</span></span>
    </div>
  <% } else if (component.status === 'retired') { %>
    <div class="card" style="border-left:3px solid #EF4444; background:#FFF5F5;">
      <span style="color:#991B1B;font-size:13px;">该部件已退役，所有操作已关闭。</span>
      <span style="color:#666;font-size:12px;margin-left:8px;">当前状态：<span class="badge badge-retired">retired</span></span>
    </div>
  <% } %>

  <div class="detail-card">
    <h2><%= component.component_sn %></h2>
    <table>
      <tr><td>型号</td><td><%= component.model_name %> (<%= component.category %>)</td></tr>
      <tr><td>批次号</td><td><%= component.batch_number %></td></tr>
      <tr><td>生产日期</td><td><%= component.production_date %></td></tr>
      <tr><td>状态</td><td><span class="badge badge-<%= component.status %>"><%= component.status %></span></td></tr>
      <tr><td>累计使用时长</td><td><%= component.cumulative_hours %> 小时</td></tr>
      <tr><td>设计寿命</td><td><%= component.design_life_hours %> 小时</td></tr>
      <tr><td>备注</td><td><%= component.notes || '—' %></td></tr>
    </table>
  </div>

  <h2>安装历史</h2>
  <table>
    <thead>
      <tr>
        <th>飞机</th>
        <th>位置</th>
        <th>安装时间</th>
        <th>拆卸时间</th>
        <th>安装原因</th>
        <th>拆卸原因</th>
        <th>操作员</th>
      </tr>
    </thead>
    <tbody>
      <% if (installHistory.length) { %>
        <% installHistory.forEach(function(h) { %>
          <tr>
            <td><%= h.aircraft_sn %> (<%= h.aircraft_model %>)</td>
            <td><%= h.position %></td>
            <td><%= h.installed_at %></td>
            <td><%= h.removed_at || '当前在位' %></td>
            <td><%= h.install_reason %></td>
            <td><%= h.removal_reason || '—' %></td>
            <td><%= h.operator_name || '—' %></td>
          </tr>
        <% }); %>
      <% } else { %>
        <tr><td colspan="7">暂无安装记录</td></tr>
      <% } %>
    </tbody>
  </table>

  <p style="margin-top:12px;"><a href="/components" class="btn">← 返回部件列表</a></p>

<% } %>
